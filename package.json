{
  "name": "pinned-files",
  "version": "1.1.1",
  "description": "Pin files for quick access in a simple sidebar view.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
