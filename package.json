  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "esbuild": "0.17.3",
    "obsidian": "^1.13.1",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  }
}
